<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface" tools:context=".MainActivity">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/simpleTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabBackground="?attr/colorSurfaceContainer" app:tabIndicatorColor="?attr/colorPrimary"       app:tabSelectedTextColor="?attr/colorPrimary"   app:tabTextColor="?attr/colorOnSurfaceVariant"   app:tabIndicatorAnimationMode="elastic"         app:tabGravity="fill"
        app:tabMode="fixed" />

    <FrameLayout
        android:id="@+id/simpleFrameLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
