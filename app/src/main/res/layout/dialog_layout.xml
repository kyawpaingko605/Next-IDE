<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" 
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainerLow" 
    android:paddingBottom="16dp">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:id="@+id/dialoglayoutLinearLayout1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/colorSecondaryContainer" 
            android:clipToOutline="true">

            <ImageView
                android:id="@+id/avatar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher"
                android:scaleType="centerCrop"
                android:tint="?attr/colorOnSecondaryContainer" />
        </FrameLayout>

        <TextView
            android:id="@+id/dialoglayoutTextView1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="/storage/emulated/0/AppProjects/"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:ellipsize="start"
            android:singleLine="true" />

    </LinearLayout>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:dividerColor="?attr/colorOutlineVariant" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/bs_rv"
        android:layout_width="match_parent"
        android:layout_height="240dp" 
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

</LinearLayout>
